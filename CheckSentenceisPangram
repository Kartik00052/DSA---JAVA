class Solution {
    public boolean checkIfPangram(String sentence) {
    Set<Character> aSet=new HashSet<>();
    for(int i='a';i<='z';i++){
        aSet.add((char)i);
    }  
   for(int i=0;i<sentence.length();i++){
    aSet.remove(sentence.charAt(i));
    if(aSet.isEmpty())
      return true;
   }
   return false;
    }
}
