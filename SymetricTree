class Solution {
    private boolean check(TreeNode l,TreeNode r){
        if(l==null&&r==null){
            return true;
        }
        if(l==null||r==null){
            return false;
        }
        if((l.val==r.val) && check(l.right,r.left) && check(l.left,r.right)){
            return true;
        }
        return false;
    }
    public boolean isSymmetric(TreeNode root) {
        if(root==null)
         return true;
    return check(root.left,root.right);  
    }
}
